# ─────────────────────────────────────────────────────────────────────────────
# SOAR Incident Containment Engine – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development         # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – Day 1 development)
DATABASE_URL=sqlite:///./soar.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/soar_db

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-before-deploying
ALLOWED_HOSTS=*

# ── Future – Threat Intelligence APIs (Day 3+) ────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
SHODAN_API_KEY=your-shodan-api-key

# ── Future – SIEM Integration (Day 5+) ───────────────────────────────────────
SPLUNK_HOST=your-splunk-host
SPLUNK_TOKEN=your-splunk-token
